# MongoDB
MONGODB_URI=mongodb://localhost:27017/newsaddaindia

# Push Notifications (Web Push) - generate with: npm run push:generate-keys
VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here

# Optional: frontend URL for CORS and notification links (comma-separated for multiple)
# FRONTEND_URL=http://localhost:4200

# YouTube Data API v3 — latest video for video banner (https://console.cloud.google.com/apis/library/youtube.googleapis.com)
# Copy these into backend/.env (not committed). Example values only:
# YOUTUBE_API_KEY=your_youtube_data_api_key
# YOUTUBE_CHANNEL_HANDLE=newsaddaindialive
# Latest banner uses the channel "Videos" playlist (no Shorts), not raw uploads.
